    "LM-Studio":
    {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LM Studio (local)",
      "options":
      {
        "baseURL": "http://127.0.0.1:11444/v1"
      },
      "models":
      {
        "gpt-oss-safeguard-120b-mlx" :
        {
          "name": "completion+tools gpt-oss-safeguard-120b-mlx",
          "limit": 
          { 
            "context": 256000,
