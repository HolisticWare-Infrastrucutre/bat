      phind-codellama:34b                            566e1b629c44    19        GB 8 weeks      completion
      mistral-large:latest                           bbcf36dc47ad    73        GB 8 weeks      completion,tools
      mistral-large:123b                             bbcf36dc47ad    73        GB 8 weeks      completion,tools
      phind-codellama:latest                         566e1b629c44    19        GB 8 weeks      completion
      codegemma:latest                               0c96700aaada    5.0       GB 8 weeks      completion
      deepseek-coder-v2:236b                         c78d80129305    132       GB 8 weeks      completion,insert
      deepseek-coder-v2:latest                       63fb193b3a9b    8.9       GB 8 weeks      completion,insert
