  },
  // Tool Configuration
  // https://opencode.ai/docs/tools
  "tools":
  {
    "read": true,
    "write": true,
    "edit": true,
    "bash": true,
    "grep": true,
    "glob": true,
    "list": true,
    "git": true,
    "filesystem": true,
    "lsp": true,
    "playwright": true,
    // Enable the skill loading tool
    "skill": true,
    "todowrite": true,
    "todoread": true,
    "webfetch": true,
    // OPENCODE_ENABLE_EXA=1 opencode
    "websearch": true,
    "question": true,
    /*
    "git*": false,
    "time*": false,
    "fetch*": false,
    "firecrawl*": false,
    "brave-search*": false,
    "duckduckgo*": false,
    "context7*": false,
    "playwright*": false,
    */
  },
  // === Permissions ===
  // Permission Configuration
  "permission":
  {
    // "*": "ask",
    // .env reads without prompts
    /*
    "read":
    {
      ".env": "allow",
      ".env.*": "allow",
      ".env-*": "allow"
    },
    */
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    // Only deny the truly catastrophic - everything else just runs
    "bash":
    {
      "git push": "allow",
      "git push *": "allow",
      "sudo *": "deny",
      "rm -rf /": "deny",
      "rm -rf /*": "deny",
      "rm -rf ~": "deny",
      "rm -rf ~/*": "deny",
      ":(){:|:&};:": "deny",  // fork bomb, just in case

      // ✅ Safe Git commands (read-only)
      "git status": "allow",
      "git status*": "allow",
      "git log*": "allow",
      "git diff*": "allow",
      "git show*": "allow",
      "git branch": "allow",
      "git branch -v*": "allow",
      "git remote -v": "allow",
      "git ls-files*": "allow",

      // ✅ Modern CLI tools (preferred - read-only)
      "rg*": "allow",          // ripgrep - better grep
      "fd*": "allow",          // fd - better find
      "bat*": "allow",         // bat - better cat
      "eza*": "allow",         // eza - better ls
      "jq*": "allow",          // jq - JSON processing
      "fzf*": "allow",         // fzf - fuzzy finder

      // ✅ Traditional shell commands (fallback)
      "ls": "allow",
      "ls *": "allow",
      "pwd": "allow",
      "cat *": "allow",
      "head *": "allow",
      "tail *": "allow",
      "wc *": "allow",
      "which *": "allow",
      "find *": "allow",
      "grep *": "allow",

      // ⚠️ Git state changes - Ask (modifies repo)
      "git add*": "ask",
      "git commit*": "ask",
      "git push*": "ask",
      "git pull*": "ask",
      "git fetch*": "ask",
      "git checkout*": "ask",
      "git switch*": "ask",
      "git merge*": "ask",
      "git rebase*": "ask",
      "git reset*": "ask",
      "git branch -d*": "ask",
      "git branch -D*": "ask",
      "git stash*": "ask",
      "git restore*": "ask",

      // ✅ GitHub CLI (read-only commands)
      "gh repo view*": "allow",
      "gh pr view*": "allow",
      "gh pr list*": "allow",
      "gh issue view*": "allow",
      "gh issue list*": "allow",
      "gh run view*": "allow",
      "gh run list*": "allow",
      "gh api*": "allow",      // API calls (mostly read)

      // ⚠️ GitHub CLI - State changes (ask)
      "gh pr create*": "ask",
      "gh pr merge*": "ask",
      "gh pr close*": "ask",
      "gh issue create*": "ask",
      "gh issue close*": "ask",
      "gh run cancel*": "ask",
      "gh run rerun*": "ask",

          // ✅ Custom CLI tools (your hooks)
      "node */gloomstalker/cli.js*": "allow",
      "node */todo-enforcer/cli.js*": "allow",
      "node */risk-assessor/cli.js*": "allow",

      // ✅ Process inspection (for service management)
      "lsof*": "allow",
      "ps *": "allow",
      "pgrep*": "allow",
      "curl -s http://localhost*": "allow",
      "curl -s https://localhost*": "allow",

      // ✅ Docker inspection (read-only)
      "docker ps*": "allow",
      "docker images*": "allow",
      "docker logs*": "allow",
      "docker inspect*": "allow",
      "docker-compose ps*": "allow",
      "docker-compose logs*": "allow",

      // ⚠️ Docker operations - Ask (can affect services)
      "docker start*": "ask",
      "docker stop*": "ask",
      "docker restart*": "ask",
      "docker rm*": "ask",
      "docker rmi*": "ask",
      "docker-compose up*": "ask",
      "docker-compose down*": "ask",
      "docker-compose restart*": "ask",

      // ✅ Kubernetes inspection (read-only)
      "kubectl get*": "allow",
      "kubectl describe*": "allow",
      "kubectl logs*": "allow",

      // ⚠️ Kubernetes operations - Ask (can affect cluster)
      "kubectl apply*": "ask",
      "kubectl delete*": "ask",
      "kubectl scale*": "ask",
      "kubectl rollout*": "ask",

      // ⚠️ Package managers - Ask (can be slow/change state)
      "npm test*": "ask",
      "npm run*": "ask",
      "npm install*": "ask",
      "npm ci*": "ask",
      "npx*": "ask",
      "yarn*": "ask",
      "bun test*": "ask",
      "bun run*": "ask",
      "bun install*": "ask",
      "bun add*": "ask",
      "bun x*": "ask",         // bunx equivalent

      
      // ⚠️ Process management - Ask (can disrupt services)
      "pkill*": "ask",
      "kill*": "ask"
    },
    // Skill permissions - allow all project skills by default
    "skill":
    {
      // Project-specific skills
      /*
      "write-concept": "allow",
      "fact-check": "allow",
      "seo-review": "allow",
      "test-writer": "allow",
      "resource-curator": "allow",
      "concept-workflow": "allow",
      // Default behavior for other skills
      */
      "*": "ask"
    }
  },
  // https://opencode.ai/docs/custom-tools/#write-a-tool-in-python
  "mcp":
  {
    // Web fetching - MCP official server (Python via uvx)
    /*
    "fetch":
    {
      "type": "local",
      "command": ["bunx", "-y", "@modelcontextprotocol/server-fetch"],
      "enabled": true
    },
    */
    "fetch-mcp":
    {
      "type": "local",
      "enabled": true,
      "command": ["bunx", "-y", "@modelcontextprotocol/server-fetch"],
    },
    "git": 
    {
      "type": "local",
      "enabled": true,
      "command": ["uvx", "-y", "@modelcontextprotocol/server-git"]
    },
    "microsoft-docs":
    {
        "type": "remote",
        "enabled": true,
        "url": "https://learn.microsoft.com/api/mcp",
    },
    "context7":
    {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
      "headers":
      {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      },
    },
    "context7-slow":
    {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.context7.com/mcp",
    },
    "ddg-search":
    {
      "type": "local",
      "enabled": true,
      "command": ["uvx", "duckduckgo-mcp-server"],
    },
    /*
      https://api-dashboard.search.brave.com/documentation/pricing

      Note: The Brave Search MCP server may require additional setup, such as installing the 
      @brave/brave-search-mcp-server package and configuring the BRAVE_API_KEY environment variable. 
      Ensure you have the necessary dependencies and credentials to use this tool effectively.
    
      BRAVE_API_KEY=xxxxxx npx -y @brave/brave-search-mcp-server --transport stdio
      BRAVE_API_KEY=xxxxxx bunx -y @brave/brave-search-mcp-server --transport stdio

    "brave-search": 
    {
      "type": "local",
      "command": ["bunx", "-y", "@brave/brave-search-mcp-server", "--transport", "stdio"],
      "environment": { "BRAVE_API_KEY": "{env:BRAVE_API_KEY}" }
    },
    */
    "duckduckgo":
    {
        "type": "local",
        "enabled": true,
        "command": ["uvx", "duckduckgo-mcp-server"],
    },
    "firecrawl":
    {
        "type": "local",
        "enabled": true,
        "environment": { "FIRECRAWL_API_KEY": "{env:FIRECRAWL_API_KEY}" },
        "command": ["bunx",
        "-y",
        "firecrawl-mcp"
      ],
    },
    "exa": {
      "type": "local",
      "command": ["npx", "-y", "exa-mcp-server"],
      "environment": {
        "EXA_API_KEY": "your-key"
      }
    },
    "web-search": 
    {
      "type": "local",
      "command": 
      [
        "npx",
        "open-websearch@latest"
      ],
      "environment": 
      {
        "MODE": "stdio",
        "DEFAULT_SEARCH_ENGINE": "duckduckgo",
        "ALLOWED_SEARCH_ENGINES": "duckduckgo,bing,exa,brave,google"
      }
    },
    // https://deepwiki.com/
    "DeepWiki":
    {
      "type": "remote",
      "enabled": true,
      "url": "https://mcp.deepwiki.com/mcp",
    },
    "serena": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena-mcp-server",
        "--context",
        "ide-assistant",
        "--project",
        "$(pwd)"
      ],
      "enabled": true
    },
    "github":
    {
      "type": "local",
      "command": ["bunx", "@modelcontextprotocol/server-github"],
      "environment":
      {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{env:GITHUB_PERSONAL_ACCESS_TOKEN}",
        "GITHUB_TOOLSETS": "repos,issues,pull_requests,actions,code_security"
      }
    },
    "github-grep":
    {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "github-copilot":
    {
      "type": "remote",
      "enabled": true,
      "url": "https://api.githubcopilot.com/mcp/",
      "headers":
      {
        "Authorization": "Bearer <REDACTED_GITHUB_TOKEN>"
      }
    },
    "gitlab":
    {
      "type": "local",
      "enabled": true,
      "command": ["npx", "-y", "@zereight/mcp-gitlab"],
      "environment":
      {
        "GITLAB_PERSONAL_ACCESS_TOKEN": "{env:GITLAB_PERSONAL_ACCESS_TOKEN}",
        "GITLAB_API_URL": "https://gitlab.com/api/v4/",
      },
    },
    "filesystem":
    {
      "type": "local",
      "enabled": true,
      "command": [ "npx",
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "${workspaceFolder}"
      ]
    },
    "playwright-mcp":
    {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "enabled": true
    },
    "playwright":
    {
      "type": "local",
      "command": ["bunx", "-y", "@executeautomation/playwright-mcp-server"],
      "enabled": true
    },
    "chrome-devtools":
    {
      "type": "local",
      "command": 
      [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": true,
    },
    "memory": 
    {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
    },
    "sequential-thinking":
    {
      "type": "local",
      "enabled": true,
      "command":
      [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking",
      ],
    },
    // https://github.com/sethships/RefactorCsharpMCP
    /*
    "refactor-csharp-mcp-docker": 
    {
      "command": "docker",
      "args": ["run", "--rm", "-i", "refactor-csharp-mcp:latest"],
      "type": "stdio"
    },
    */
  },
  "agent": 
  {
    "build": 
    {
      "mode": "primary",
      "tools": 
      {
        "write": true,
        "edit": true,
        "bash": true,
        "webfetch": true,
        "git*": true,
        "time*": true,
      },
    },
    "plan": 
    {
      "mode": "primary",
      "tools": 
      {
          "write": false,
          "edit": false,
          "bash": true,
          "webfetch": true,
      },
    },
  },
  "lsp":
  {
    "bash": 
    {
      "command": ["npx", "--yes", "bash-language-server", "start"],
      "extensions": [".sh", ".bash"]
    },
    "pyright": {
      "command": ["npx", "--yes", "pyright", "--stdio"],
      "extensions": [".py", ".pyi"]
    },
    "yaml-ls": {
      "command": ["npx", "--yes", "yaml-language-server", "--stdio"],
      "extensions": [".yaml", ".yml"]
    },
    "json": {
      "command": ["npx", "--yes", "vscode-json-languageserver", "--stdio"],
      "extensions": [".json", ".jsonc"]
    }
  },
  // 7.--- IGNORE PATTERNS ---
  // Critical for performance. Keep the agent out of these folders.
  "watcher": 
  {
    "ignore": 
    [
      ".git/**", // Git metadata/history; very heavy to index
      ".aider*", // Aider's internal chat history, tags, and cache
      ".aider*", // Excludes chat history, tags cache, and input history
      ".opencode_history", // Prevents the agent from reading its own past chat logs
      ".opencode_storage", // OpenCode internal database and temporary state
      "node_modules/**", // JavaScript dependencies; massive token waste
      "package-lock.json", // Large auto-generated JS dependency tree
      "uv.lock", // Auto-generated Python dependency resolution
      "**/__pycache__/**", // Python compiled bytecode; noise for the LLM
      "**/.pytest_cache/**", // Temporary test data
      "**/.venv/**", // Virtual environment binaries and library source
      "**/.ruff_cache/**", // Linting metadata
      "**/.mypy_cache/**", // Type checking metadata
      "**/.coverage", // Binary coverage data
      "coverage.xml", // Formatted coverage data
      "dist/**", // Build artifacts
      ".env" // Keep your secrets out of the LLM context
    ]
  },  
  "formatter":
  {
    "dotnet format":
    {
      "command": ["dotnet", "format", "--include", "$FILE"],
      "extensions": [".cs"]
    }
  }
}