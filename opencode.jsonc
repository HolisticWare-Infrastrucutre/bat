      phi4:latest                                    ac896e5b8b34    9.1       GB 8 weeks      completion
      deepseek-r1:latest                             6995872bfe4c    5.2       GB 8 weeks      completion,thinking
      nomic-embed-text:latest                        0a109f422b47    274       MB 8 weeks      embedding
      phi3.5:latest                                  61819fb370a3    2.2       GB 8 weeks      completion
      llama3.2-vision:latest                         6f2f9757ae97    7.8       GB 8 weeks      completion,vision
      phi:latest                                     e2fd6321a5fe    1.6       GB 8 weeks      completion
