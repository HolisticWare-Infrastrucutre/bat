{
  // https://opencode.ai/docs
  // https://opencode.ai/docs/config/
  // https://github.com/search?q=path%3A**%2Fopencode.jsonc&type=code
  "$schema": "https://opencode.ai/config.json",
  // Theme configuration
  "theme": "opencode",
  "autoupdate": true,
  "provider":
  {
    "ollama":
