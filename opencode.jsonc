    "llama-cpp":
    {      
      "name": "llama.cpp (local)",
      "options": 
      {
        "baseURL": "http://127.0.0.1:11454/v1"
      },
      "models": 
      {
          "unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q3_K_M": 
          {
            "name": "unsloth/Qwen3-Coder-30B-A3B-Instruct-GGUF:Q3_K_M",
            "tools": true
        }
      }
